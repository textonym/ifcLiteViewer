{
  "dataRoles": [
    {
      "name": "modelUrl",
      "kind": "Grouping",
      "displayName": "IFC Model URL",
      "description": "A column containing the URL of the IFC file to display"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "modelUrl": { "max": 1 }
        }
      ],
      "table": {
        "rows": {
          "select": [
            { "for": { "in": "modelUrl" } }
          ]
        }
      }
    }
  ],
  "objects": {},
  "sorting": {
    "default": {}
  },
  "supportsHighlight": false,
  "supportsEmptyDataView": true,
  "supportsLandingPage": true,
  "privileges": [
    {
      "name": "WebAccess",
      "essential": true,
      "parameters": ["*"]
    }
  ]
}
